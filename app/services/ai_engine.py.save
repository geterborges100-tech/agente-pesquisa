"""
app/services/ai_engine.py
Motor de IA — orquestrador do Sprint 3.

Pipeline por chamada
--------------------
1. Carregar script ativo          (ScriptLoader)
2. Resolver nó atual da conversa  (Conversation.current_node_key)
3. Buscar histórico de mensagens  (DB query)
4. Montar prompt                  (PromptBuilder)
5. Chamar LLM                     (LLMClient)
6. Validar resposta                (GuardrailValidator)
7. Persistir Message outbound      (DB)
8. Enviar outbound                 (EvolutionOutboundClient)
9. Avançar estado da conversa      (StateMachine + next_node_key)

Transições de estado
--------------------
    OPEN    → ACTIVE   : início do roteiro
    ACTIVE  → WAITING  : pergunta enviada, aguarda resposta
    WAITING → ACTIVE   : resposta recebida, próxima pergunta enviada
    ACTIVE  → CLOSED   : nó "end" alcançado
"""

from __future__ import annotations

import logging
import uuid
from datetime import datetime, timezone
from typing import Any

from sqlalchemy import select
from sqlalchemy.orm import Session

from app.models.extended_models import Message, ResearchScript
from app.models.models_v1 import Conversation
from app.services.evolution_outbound import EvolutionOutboundClient, OutboundError
from app.services.guardrail_validator import GuardrailValidator, GuardrailViolationError
from app.services.llm_client import LLMClient, LLMError
from app.services.prompt_builder import PromptBuilder
from app.services.script_loader import (
    LoadedScript,
    NoActiveScriptError,
    ScriptLoader,
    ScriptNode,
)
from app.services.state_machine import ConversationStatus, StateMachine

logger = logging.getLogger(__name__)

_FALLBACK_MESSAGE = (
    "Obrigado pela sua mensagem! "
    "Estamos processando sua resposta e entraremos em contato em breve."
)


class AIEngineError(RuntimeError):
    """Erro genérico do motor de IA."""


class AIEngine:
    """
    Orquestrador do Motor de IA.

    Parâmetros
    ----------
    db              : Session SQLAlchemy (injetada)
    llm_client      : LLMClient instanciado
    outbound_client : EvolutionOutboundClient instanciado
    validator       : GuardrailValidator (opcional — usa padrão se None)
    """

    def __init__(
        self,
        *,
        db: Session,
        llm_client: LLMClient,
        outbound_client: EvolutionOutboundClient,
        validator: GuardrailValidator | None = None,
    ) -> None:
        self._db             = db
        self._llm            = llm_client
        self._outbound       = outbound_client
        self._validator      = validator or GuardrailValidator()
        self._script_loader  = ScriptLoader(db)
        self._state_machine  = StateMachine()

    # ------------------------------------------------------------------
    # Entrypoint público
    # ------------------------------------------------------------------

    def process_inbound(
        self,
        *,
        conversation: Conversation,
        contact_phone: str,
        inbound_text: str | None,
        account_id: uuid.UUID,
    ) -> dict[str, Any]:
        """
        Processa uma mensagem inbound e executa o pipeline completo.

        Returns
        -------
        dict com campos: status, node_key, outbound_text (ou error).
        """
        conv_id = str(conversation.id)
        logger.info("[AIEngine] Iniciando pipeline conversation_id=%s", conv_id)

        # ── 1. Carregar script ativo ─────────────────────────────────
        try:
            script = self._script_loader.load_active(account_id)
        except NoActiveScriptError as exc:
            logger.warning("[AIEngine] %s — abortando.", exc)
            return {"status": "no_script", "error": str(exc)}

        # ── 2. Resolver nó atual ─────────────────────────────────────
        node = self._resolve_node(conversation, script)
        if node is None:
            logger.info("[AIEngine] Conversa já encerrada conversation_id=%s", conv_id)
            return {"status": "closed", "node_key": None}

        # ── 3. Histórico de mensagens ────────────────────────────────
        history = self._load_history(conversation.id)

        # ── 4. Montar prompt ─────────────────────────────────────────
        objective = self._get_objective(account_id)
        builder = PromptBuilder(objective=objective)
        prompt_payload = builder.build(
            history=PromptBuilder.history_from_messages(history),
            current_node=node,
            inbound_text=inbound_text,
        )

        # ── 5. Chamar LLM ────────────────────────────────────────────
        try:
            raw_response = self._llm.complete(prompt_payload)
        except LLMError as exc:
            logger.error("[AIEngine] LLM falhou: %s", exc)
            outbound_text = _FALLBACK_MESSAGE
        else:
            # ── 6. Validar ──────────────────────────────────────────
            try:
                outbound_text = self._validator.validate(raw_response)
            except GuardrailViolationError as exc:
                logger.warning("[AIEngine] Guardrail: %s — usando fallback.", exc.violations)
                outbound_text = _FALLBACK_MESSAGE

        # ── 7. Persistir mensagem outbound ───────────────────────────
        self._persist_outbound(conversation.id, outbound_text)

        # ── 8. Enviar outbound ────
        send_ok = self._send_outbound(contact_phone, outbound_text)

	# ── 9. Avançar estado e nó ────
	next_status, next_node_key = self._advance(conversation, node)

	try:
	    self._db.commit()
	    logger.info(
	        "[AIEngine] Estado persistido no banco: node=%s status=%s",
        	next_node_key,
        	next_status,
    		)
except Exception as e:
    self._db.rollback()
    logger.error("[AIEngine] Erro ao persistir estado: %s", e)
    return {
        "status": "db_commit_failed",
        "error": str(e),
        "node_key": node.key,
        "next_node_key": next_node_key,
        "conv_status": next_status,
        "outbound_text": outbound_text,
    }


        result: dict[str, Any] = {
            "status":        "ok" if send_ok else "send_failed",
            "node_key":      node.key,
            "next_node_key": next_node_key,
            "conv_status":   next_status,
            "outbound_text": outbound_text,
        }
        logger.info("[AIEngine] Pipeline concluído: %s", result)
        return result

    # ------------------------------------------------------------------
    # Helpers privados
    # ------------------------------------------------------------------

    def _resolve_node(
        self, conversation: Conversation, script: LoadedScript
    ) -> ScriptNode | None:
        """Determina o nó a ser processado neste turno."""
        if conversation.status == ConversationStatus.CLOSED:
            return None

        current_key = conversation.current_node_key
        if not current_key:
            # Primeiro turno: usar nó inicial do roteiro
            return script.start_node()

        node = script.get_node(current_key)
        if node is None:
            logger.warning(
                "[AIEngine] Nó '%s' não encontrado no script — usando start.",
                current_key,
            )
            return script.start_node()
        return node

    def _load_history(self, conversation_id: uuid.UUID) -> list[Message]:
        """Carrega as últimas 20 mensagens da conversa."""
        stmt = (
            select(Message)
            .where(Message.conversation_id == conversation_id)
            .order_by(Message.sent_at.asc())
            .limit(20)
        )
        return list(self._db.scalars(stmt).all())

    def _get_objective(self, account_id: uuid.UUID) -> str:
        """Busca o objetivo do script ativo (para o system prompt)."""
        stmt = (
            select(ResearchScript.objective)
            .where(
                ResearchScript.account_id == account_id,
                ResearchScript.status == "active",
            )
            .limit(1)
        )
        return self._db.scalar(stmt) or "Coletar informações do participante."

    def _persist_outbound(
        self, conversation_id: uuid.UUID, text: str
    ) -> None:
        msg = Message(
            conversation_id=conversation_id,
            direction="outbound",
            sender_type="ai",
            raw_text=text,
            sent_at=datetime.now(tz=timezone.utc),
        )
        self._db.add(msg)

    def _send_outbound(self, phone: str, text: str) -> bool:
        try:
            self._outbound.send_text(number=phone, text=text)
            return True
        except OutboundError as exc:
            logger.error("[AIEngine] Falha no envio outbound: %s", exc)
            return False

    def _advance(
        self, conversation: Conversation, current_node: ScriptNode
    ) -> tuple[str, str | None]:
        """
        Avança o estado da conversa e o current_node_key.

        Returns
        -------
        (new_status, next_node_key)
        """
        current_status = conversation.status

        if current_node.node_type == "end" or current_node.next_key is None:
            # Roteiro concluído
            new_status = StateMachine.transition(current_status, ConversationStatus.CLOSED)
            conversation.status = new_status
            conversation.current_node_key = None
            return new_status, None

        # Avança ao próximo nó
        next_node_key = current_node.next_key
        conversation.current_node_key = next_node_key

        # Após enviar uma pergunta, o destino final sempre é WAITING.
        # OPEN precisa passar por ACTIVE antes de chegar em WAITING.
        if current_status == ConversationStatus.OPEN:
            # OPEN → ACTIVE → WAITING (dois saltos lógicos, um commit só)
            StateMachine.transition(current_status, ConversationStatus.ACTIVE)  # valida
            new_status = StateMachine.transition(ConversationStatus.ACTIVE, ConversationStatus.WAITING)
        elif current_status == ConversationStatus.WAITING:
            # WAITING → ACTIVE → WAITING (respondeu → pergunta seguinte)
            StateMachine.transition(current_status, ConversationStatus.ACTIVE)  # valida
            new_status = StateMachine.transition(ConversationStatus.ACTIVE, ConversationStatus.WAITING)
        elif StateMachine.can_transition(current_status, ConversationStatus.WAITING):
            new_status = StateMachine.transition(current_status, ConversationStatus.WAITING)
        else:
            new_status = current_status

        conversation.status = new_status
        return new_status, next_node_key
