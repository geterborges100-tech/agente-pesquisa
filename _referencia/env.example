# Copie para .env e preencha antes de subir
# cp .env.example .env

# PostgreSQL
POSTGRES_USER=agent
POSTGRES_PASSWORD=troque_esta_senha
POSTGRES_DB=research_agent

# Conexão (usada pela api — aponta para o serviço 'db' do docker-compose)
DATABASE_URL=postgresql+psycopg2://agent:troque_esta_senha@db:5432/research_agent

# Segurança do Webhook (gerados na Meta Developer Console)
APP_SECRET=seu_whatsapp_app_secret_aqui
VERIFY_TOKEN=token_que_voce_cadastrou_na_meta

# UUID da conta (gere com: python -c "import uuid; print(uuid.uuid4())")
ACCOUNT_ID=00000000-0000-0000-0000-000000000001

# Opcional: loga SQL gerado pelo SQLAlchemy
SQL_ECHO=false
